# ============================================================
# cf-access-alert — environment variables
# ============================================================
# SECURITY: This file contains secrets. Set permissions:
#   chmod 600 .env
#   chown root:root .env  (or your deploy user)
#
# NEVER commit this file to git.
# ============================================================

# --- Cloudflare ---
# API token scoped to: Account > Access: Audit Logs > Read
CF_API_TOKEN=your_cloudflare_api_token_here
CF_ACCOUNT_ID=your_cloudflare_account_id_here

# Optional: comma-separated Access app UIDs to monitor (leave empty for all apps)
# Find UIDs via CF Zero Trust dashboard or from the API response
CF_APP_UIDS=

# --- Pushover (optional — need at least one of Pushover or Discord) ---
PUSHOVER_USER_KEY=
PUSHOVER_APP_TOKEN=
PUSHOVER_PRIORITY=0
PUSHOVER_SOUND=pushover

# --- Discord (optional — need at least one of Pushover or Discord) ---
DISCORD_WEBHOOK_URL=

# --- Polling ---
# How often to check (seconds). Default: 300 (5 min)
POLL_INTERVAL=300

# How far back to look each poll for delayed events (seconds). Default: 600 (10 min)
LOOKBACK_BUFFER=600

# Max catchup window after container downtime (seconds). Default: 604800 (7 days)
MAX_CATCHUP=604800

# --- Notification retry ---
# Number of retry attempts per notification. Default: 3
NOTIFY_RETRIES=3

# Base delay between retries in seconds (doubles each attempt). Default: 10
NOTIFY_RETRY_DELAY=10

# --- Timezone ---
TZ=Europe/Amsterdam

# --- Logging ---
# INFO (default) or DEBUG for verbose troubleshooting
LOG_LEVEL=INFO