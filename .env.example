# ============================================================
# cf-access-alert — environment variables
# ============================================================
# SECURITY: This file contains secrets. Set permissions:
#   chmod 600 .env
#   chown root:root .env  (or your deploy user)
#
# NEVER commit this file to git.
# ============================================================

# --- Cloudflare ---
# API token scoped to: Account > Access: Audit Logs > Read
CF_API_TOKEN=your_cloudflare_api_token_here
CF_ACCOUNT_ID=your_cloudflare_account_id_here

# Optional: comma-separated Access app UIDs to monitor (leave empty for all apps)
# Find UIDs via CF Zero Trust dashboard or from the API response
CF_APP_UIDS=

# --- Pushover (optional — need at least one of Pushover, Discord, or ntfy) ---
PUSHOVER_USER_KEY=
PUSHOVER_APP_TOKEN=
PUSHOVER_PRIORITY=0
PUSHOVER_SOUND=pushover

# --- Discord (optional — need at least one of Pushover, Discord, or ntfy) ---
DISCORD_WEBHOOK_URL=

# --- ntfy (optional — need at least one of Pushover, Discord, or ntfy) ---
# Works with ntfy.sh (default) or any self-hosted ntfy instance
NTFY_URL=https://ntfy.sh
NTFY_TOPIC=
NTFY_TOKEN=
NTFY_PRIORITY=4

# --- Burst detection ---
# If the same IP is blocked >= BURST_THRESHOLD times within BURST_WINDOW,
# send one "brute-force detected" summary instead of individual alerts.
BURST_THRESHOLD=5
BURST_WINDOW=5m

# --- Daily digest ---
# Send a periodic summary of all blocked events to all notification channels.
DIGEST_ENABLED=true
DIGEST_TIME=08:00

# --- Polling ---
# How often to check. Supports: 30s, 5m, 1h, 1d (or plain seconds)
POLL_INTERVAL=5m

# How far back to look each poll for delayed events
LOOKBACK_BUFFER=10m

# Max catchup window after container downtime
MAX_CATCHUP=7d

# --- Notification retry ---
# Number of retry attempts per notification. Default: 3
NOTIFY_RETRIES=3

# Base delay between retries (doubles each attempt). Supports: 10s, 1m, etc.
NOTIFY_RETRY_DELAY=10s

# --- Timezone ---
TZ=Europe/Amsterdam

# --- Logging ---
# INFO (default) or DEBUG for verbose troubleshooting
LOG_LEVEL=INFO